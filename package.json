{
    "private": true,
    "type": "module",
    "scripts": {
        "build": "pnpm run build:firefox",
        "build:firefox": "vite build --mode firefox",
        "build:chromium": "vite build --mode chromium",
        "debug": "pnpm run debug:firefox",
        "debug:firefox": "pnpm run build:firefox --watch",
        "debug:chromium": "pnpm run build:chromium --watch",
        "debug:firefox-android": "vite build --mode firefox-android --watch",
        "clean": "node -e \"(await import('fs')).rmSync('dist', { recursive: true, force: true })\"",
        "type-check": "pnpm run lint:tsc",
        "lint": "pnpm run lint:tsc & pnpm run lint:eslint & pnpm run lint:stylelint",
        "lint:tsc": "vue-tsc --build --noEmit",
        "lint:eslint": "eslint .",
        "lint:stylelint": "stylelint **/*.{css,vue}",
        "format": "pnpm run format:eslint & pnpm run format:stylelint",
        "format:eslint": "eslint --fix .",
        "format:stylelint": "stylelint --fix **/*.{css,vue}"
    },
    "dependencies": {
        "bootstrap-icons": "^1.13.1",
        "pinia": "^3.0.4",
        "solid-js": "^1.9.11",
        "vue": "^3.5.30"
    },
    "devDependencies": {
        "@antfu/eslint-config": "^7.7.3",
        "@csstools/stylelint-formatter-github": "^2.0.0",
        "@stylistic/stylelint-config": "^4.0.0",
        "@types/chrome": "^0.1.38",
        "@types/node": "^24.12.0",
        "@types/webextension-polyfill": "^0.12.5",
        "@unocss/eslint-plugin": "^66.6.6",
        "@unocss/postcss": "^66.6.6",
        "@vitejs/plugin-vue": "^6.0.5",
        "crx": "^5.0.1",
        "eslint": "^10.0.3",
        "eslint-import-resolver-typescript": "^4.4.4",
        "eslint-plugin-import-x": "^4.16.2",
        "eslint-plugin-solid": "^0.14.5",
        "globals": "^17.4.0",
        "lightningcss": "1.30.1",
        "postcss": "^8.5.8",
        "stylelint": "^17.4.0",
        "stylelint-config-recess-order": "^7.6.1",
        "stylelint-config-recommended-vue": "^1.6.1",
        "stylelint-config-standard": "^40.0.0",
        "stylelint-use-nesting": "^6.0.2",
        "typescript": "^5.9.3",
        "unocss": "^66.6.6",
        "vite": "^7.3.1",
        "vite-plugin-solid": "^2.11.11",
        "vite-svg-loader": "^5.1.1",
        "vue-tsc": "^3.2.6",
        "web-ext": "^10.0.0"
    },
    "devEngines": {
        "runtime": {
            "name": "node",
            "version": ">=24.11",
            "onFail": "error"
        },
        "packageManager": {
            "name": "pnpm",
            "version": ">=10.16",
            "onFail": "error"
        }
    }
}
